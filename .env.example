# ─── Gmail IMAP ─────────────────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your_app_password_here
IMAP_INBOX=INBOX
GMAIL_LABEL_QUARANTINE=Quarantine
GMAIL_LABEL_REVIEW=Review
POLL_SECONDS=30

# ─── Database (SQLite default — no setup needed) ─────────────────────────────────
DATABASE_URL=sqlite:///./spam_personal.db
# Switch to Postgres: postgresql://user:pass@localhost:5432/spam_personal

# ─── ML Model ────────────────────────────────────────────────────────────────────
MODEL_REGISTRY=model_registry
STORE_BODY_TEXT=false

# ─── App ────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
